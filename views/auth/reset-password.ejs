<% layout("/layouts/boilerplate") %>

<section class="auth-page">
  <div class="auth-card">
    <h1>Reset Password</h1>
    <p class="form-subtitle">Set a new password for your account.</p>

    <form method="POST" action="/auth/reset-password/<%= token %>" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="newPassword" class="form-label">New Password</label>
        <input
          id="newPassword"
          name="newPassword"
          type="password"
          minlength="6"
          required
          class="form-control <%= errors.newPassword ? 'is-invalid' : '' %>"
        />
        <div class="invalid-feedback">
          <%= errors.newPassword || "Password must be at least 6 characters." %>
        </div>
      </div>

      <div class="mb-3">
        <label for="confirmPassword" class="form-label">Confirm Password</label>
        <input
          id="confirmPassword"
          name="confirmPassword"
          type="password"
          minlength="6"
          required
          class="form-control <%= errors.confirmPassword ? 'is-invalid' : '' %>"
        />
        <div class="invalid-feedback">
          <%= errors.confirmPassword || "Please confirm your password." %>
        </div>
      </div>

      <button class="btn create-listing-btn w-100" type="submit">Reset Password</button>
    </form>
  </div>
</section>
