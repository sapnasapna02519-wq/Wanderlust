<% layout("/layouts/boilerplate") %>
<%
  const isResetRequested =
    typeof resetRequested !== "undefined" ? resetRequested : false;
  const devResetLink = typeof resetLink !== "undefined" ? resetLink : null;
%>

<section class="auth-page">
  <div class="auth-card">
    <h1>Forgot Password</h1>
    <p class="form-subtitle">Enter your account email to generate a reset link.</p>

    <form method="POST" action="/auth/forgot-password" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          value="<%= formData.email || '' %>"
          class="form-control <%= errors.email ? 'is-invalid' : '' %>"
        />
        <div class="invalid-feedback">
          <%= errors.email || "Please provide a valid email address." %>
        </div>
      </div>
      <button class="btn create-listing-btn w-100" type="submit">Generate Reset Link</button>
    </form>

    <% if (isResetRequested) { %>
      <div class="alert alert-success mt-3">
        If an account exists for that email, a reset link has been sent.
      </div>
    <% } %>

    <% if (devResetLink) { %>
      <div class="alert alert-warning mt-3">
        Dev mode reset link:
        <a href="<%= devResetLink %>"><%= devResetLink %></a>
      </div>
    <% } %>

    <p class="auth-switch">
      Remembered password?
      <a href="/auth/login">Back to login</a>
    </p>
  </div>
</section>
