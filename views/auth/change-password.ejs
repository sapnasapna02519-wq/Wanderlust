<% layout("/layouts/boilerplate") %>

<section class="auth-page">
  <div class="auth-card">
    <h1>Change Password</h1>
    <p class="form-subtitle">Use a strong password you do not use elsewhere.</p>

    <form method="POST" action="/auth/change-password" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="currentPassword" class="form-label">Current Password</label>
        <input
          id="currentPassword"
          name="currentPassword"
          type="password"
          required
          class="form-control <%= errors.currentPassword ? 'is-invalid' : '' %>"
        />
        <div class="invalid-feedback">
          <%= errors.currentPassword || "Current password is required." %>
        </div>
      </div>

      <div class="mb-3">
        <label for="newPassword" class="form-label">New Password</label>
        <input
          id="newPassword"
          name="newPassword"
          type="password"
          minlength="6"
          required
          class="form-control <%= errors.newPassword ? 'is-invalid' : '' %>"
        />
        <div class="invalid-feedback">
          <%= errors.newPassword || "New password must be at least 6 characters." %>
        </div>
      </div>

      <div class="mb-3">
        <label for="confirmPassword" class="form-label">Confirm New Password</label>
        <input
          id="confirmPassword"
          name="confirmPassword"
          type="password"
          minlength="6"
          required
          class="form-control <%= errors.confirmPassword ? 'is-invalid' : '' %>"
        />
        <div class="invalid-feedback">
          <%= errors.confirmPassword || "Please confirm your new password." %>
        </div>
      </div>

      <button class="btn create-listing-btn w-100" type="submit">Update Password</button>
    </form>

    <a class="btn cancel-btn w-100 mt-2" href="/auth/profile">Back to Profile</a>
  </div>
</section>
