<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link 
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" 
        rel="stylesheet" 
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
        crossorigin="anonymous"
    />
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>
    <%- include("../includes/navbar.ejs") %>
    <div class="container">
        <% if (successMsg) { %>
            <div class="alert alert-success mt-3 flash-alert" role="alert">
                <%= successMsg %>
            </div>
        <% } %>
        <% if (errorMsg) { %>
            <div class="alert alert-danger mt-3 flash-alert" role="alert">
                <%= errorMsg %>
            </div>
        <% } %>
        <%- body %>
    </div>
    <%- include("../includes/footer.ejs") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script>
      (() => {
        const alerts = document.querySelectorAll(".flash-alert");
        if (alerts.length === 0) return;

        setTimeout(() => {
          alerts.forEach((alert) => {
            alert.style.transition = "opacity 0.35s ease";
            alert.style.opacity = "0";
            setTimeout(() => alert.remove(), 360);
          });
        }, 3500);

        const url = new URL(window.location.href);
        const hadFlashQuery =
          url.searchParams.has("success") || url.searchParams.has("error");
        if (hadFlashQuery) {
          url.searchParams.delete("success");
          url.searchParams.delete("error");
          const nextUrl = `${url.pathname}${url.search}${url.hash}`;
          window.history.replaceState({}, "", nextUrl);
        }
      })();
    </script>
</body>
</html>
