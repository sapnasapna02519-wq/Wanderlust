# ===== Required for deploy =====
NODE_ENV=production
PORT=8080
MONGO_URL=mongodb+srv://<DB_USERNAME>:<DB_PASSWORD>@<CLUSTER_URL>/wanderlust?retryWrites=true&w=majority
APP_BASE_URL=https://your-wanderlust-app.up.railway.app

# ===== SMTP (required if you use forgot-password / email notifications) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Wanderlust <your-email@gmail.com>
APP_NAME=Wanderlust

# ===== Cloudinary (required for image upload) =====
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_KEY=your-cloudinary-api-key
CLOUDINARY_SECRET=your-cloudinary-api-secret

# ===== Google OAuth (optional) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-wanderlust-app.up.railway.app/auth/google/callback

# ===== Security/rate-limit config (optional; defaults exist in code) =====
SHOW_RESET_LINK_IN_UI=false
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=8
FORGOT_RATE_LIMIT_WINDOW_MS=900000
FORGOT_RATE_LIMIT_MAX=5
RESET_RATE_LIMIT_WINDOW_MS=900000
RESET_RATE_LIMIT_MAX=6
